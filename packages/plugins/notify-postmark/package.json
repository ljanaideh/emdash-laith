{
  "name": "@emdash-cms/plugin-notify-postmark",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./sandbox": {
      "types": "./dist/sandbox-entry.d.mts",
      "import": "./dist/sandbox-entry.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --clean"
  },
  "peerDependencies": {
    "emdash": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:"
  }
}
